# When using Expo Go on a physical phone, "localhost" refers to the phone
# itself, not your computer - so use your computer's LAN IP address here
# instead, e.g. http://192.168.1.42:5000
# (Windows: run `ipconfig` and use the IPv4 Address; Mac/Linux: `ifconfig`)
EXPO_PUBLIC_SERVER_URL=http://localhost:5000
